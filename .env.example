# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is committed as a template.
# === Required for every script ===
# The base URL of your n8n instance (no trailing slash).
N8N_URL=

# === Required for any deploy/* or query/* script that talks to n8n's REST API ===
N8N_API_KEY=

# === AgentMail (only for scripts that touch AgentMail) ===
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_CREDENTIAL_ID=

# === Calendly (only for scripts that touch Calendly) ===
CALENDLY_PAT=
CALENDLY_CREDENTIAL_ID=

# === API - Agent Token (for running queries, specific to user) ===
# Generate with the 'issue.sh' script
AGENT_TOKEN=